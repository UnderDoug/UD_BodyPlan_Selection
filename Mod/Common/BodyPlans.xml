<?xml version="1.0" encoding="utf-8" ?>
<cybp_bodyplans>

  <textAddition Name="Difficult">
    <descriptionAdditions>
      This body plan will be {{r|difficult}} to play with.
    </descriptionAdditions>
    <summaryAdditions>
      {{r|Difficult to play}}
    </summaryAdditions>
    <symbol Color="r">&#x13;</symbol>
  </textAddition>
  
  <bodyplan Name="BaseRestricted">
    <restricted />
    <base />
  </bodyplan>
  
  <bodyplan Name="HumanoidWithHandsFace" Inherits="BaseRestricted">
    <restricted />
    <base />
  </bodyplan>

  <bodyplan Name="BaseDifficult">
    <difficult />
    <textAddition Name="Difficult" />
    <base />
  </bodyplan>

  <bodyplan Name="BaseMechanical">
    <mechanical />
    <descriptionAdditions>
      {{c|You will be made mechanical with this body plan.}}
    </descriptionAdditions>
    <summaryAdditions>
      {{c|You are mechanical}}
    </summaryAdditions>
    <symbol Color="c">&#x13;</symbol>
    <base />
  </bodyplan>

  <bodyplan Name="BaseTransformation">
    <optionID>EnableBodyPlansAvailableViaRecipe</optionID>
    <descriptionAdditions>
      {{m|There is a cooking recipe to get this body plan.}}
    </descriptionAdditions>
    <summaryAdditions>
      {{m|Avaialable via cooking}}
    </summaryAdditions>
    <symbol Color="m">&#xf1;</symbol>
    <base />
  </bodyplan>
  
  <bodyplan Name="SlugWithHands" Category="Mollusk" Inherits="BaseTransformation">
    <render>
      <displayName>Slug With Hands</displayName>
      <tile>Creatures/sw_slog.bmp</tile>
      <renderString>Q</renderString>
      <colorString>&amp;G</colorString>
      <tileColor>&amp;M</tileColor>
      <detailColor>G</detailColor>
    </render>
    <transformation>
      <property Name="AteCloacaSurprise" Value="true" />
      <mutations>Bilge Sphincter</mutations>
      <render>
        <tile>Creatures/sw_slog.bmp</tile>
        <renderString>Q</renderString>
      </render>
      <species>slug</species>
    </transformation>
  </bodyplan>
  
  <bodyplan Name="HumanoidOctohedron" Category="Crystal" Inherits="BaseTransformation">
    <render>
      <displayName>Humanoid Octohedron</displayName>
      <tile>Creatures/sw_crystal_body.png</tile>
      <renderString>µ</renderString>
      <colorString>&amp;Y</colorString>
      <tileColor>&amp;Y</tileColor>
      <detailColor>m</detailColor>
    </render>
    <transformation>
      <property Name="AteCrystalDelight" Value="true" />
      <mutations>Crystallinity</mutations>
      <render>
        <tile>Creatures/sw_crystal_body.png</tile>
        <renderString>µ</renderString>
      </render>
      <species>crystal</species>
    </transformation>
  </bodyplan>
  
